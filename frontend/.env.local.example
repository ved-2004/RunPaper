# ══════════════════════════════════════════════════════════
# RunPaper Frontend — Environment Variables
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════

# ── Backend API ───────────────────────────────────────────
# Development: point to local backend
# Production (GCP): set to your Cloud Run backend service URL
#   e.g. https://runpaper-backend-xxxx-uc.a.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Error monitoring (optional) ───────────────────────────
# Create a project at https://sentry.io — leave empty to disable
# In GCP Cloud Run, set this as a substitution variable in cloudbuild.yaml
NEXT_PUBLIC_SENTRY_DSN=
