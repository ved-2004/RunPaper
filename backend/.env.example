# ══════════════════════════════════════════════════════════
# RunPaper Backend — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── LLM Service (decoupled, separate private repo) ──────
# The main backend delegates all LLM work to the LLM service.
# LLM service is maintained in a separate private repository.
#
# Development setup:
#   1. Clone llm-service repo to a sibling directory:
#      ../RunPaper-LLM-Service (or your repo name)
#   2. cd ../RunPaper-LLM-Service && python -m venv venv && source venv/bin/activate
#   3. pip install -r requirements.txt
#   4. cp .env.example .env && edit .env with your API keys
#   5. python -m uvicorn api.main:app --reload --port 8001
#
# Production: Deploy LLM service to separate Cloud Run service
#
LLM_SERVICE_URL=http://localhost:8001
# Shared secret — must match LLM_SERVICE_KEY in the LLM service .env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LLM_SERVICE_KEY=change-me-to-a-random-secret

# ── Supabase (cloud storage + uploads database) ───────────
# Create a project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Direct Postgres connection string — used only by the migration runner
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Storage bucket name (create in Supabase Storage → New bucket)
SUPABASE_BUCKET=runpaper-uploads
# How many days before uploaded files expire (default: 30)
UPLOAD_TTL_DAYS=30

# ── Google OAuth2 (sign-in) ───────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (session signing) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Service URLs ──────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Application settings ──────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: Semantic Scholar citations ─────────────────
SEMANTIC_SCHOLAR_KEY=

# ── Error monitoring (Sentry) ─────────────────────────────
# Create a project at https://sentry.io — leave empty to disable
SENTRY_DSN=
ENVIRONMENT=development

