# ══════════════════════════════════════════════════════════
# RunPaper Backend — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── LLM Service ──────────────────────────────────────────
# The backend delegates all LLM work to the separate LLM service.
# Development: run the LLM service locally on port 8001
# Production (GCP): set to your Cloud Run LLM service URL
#   e.g. https://runpaper-llm-xxxx-uc.a.run.app
LLM_SERVICE_URL=http://localhost:8001
# Shared secret — must match LLM_SERVICE_KEY in the LLM service .env
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LLM_SERVICE_KEY=change-me-to-a-random-secret

# ── Supabase ──────────────────────────────────────────────
# Create a project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Direct Postgres connection string — used only by the migration runner
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Storage bucket name (create in Supabase Storage → New bucket)
SUPABASE_BUCKET=runpaper-uploads
# How many days before uploaded files expire (default: 30)
UPLOAD_TTL_DAYS=30

# ── Google OAuth2 ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (session signing) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Service URLs ──────────────────────────────────────────
# BACKEND_URL is used to construct the Google OAuth redirect URI.
# Development: http://localhost:8000
# Production (GCP): your Cloud Run backend service URL
BACKEND_URL=http://localhost:8000
# FRONTEND_URL is added to the CORS allowlist.
# Development: http://localhost:3000
# Production (GCP): your Cloud Run frontend service URL
FRONTEND_URL=http://localhost:3000

# ── Error monitoring (optional) ───────────────────────────
# Create a project at https://sentry.io — leave empty to disable
SENTRY_DSN=
# Used by Sentry to tag error reports by environment
ENVIRONMENT=development

# ── Health check metadata ─────────────────────────────────
# Tells /api/health which LLM provider key to check.
# Must match the LLM_PROVIDER set in the LLM service .env.
# Values: anthropic | openai | gemini
LLM_PROVIDER=anthropic
