# ══════════════════════════════════════════════════════════
# RunPaper Backend — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── LLM Provider (pick one) ──────────────────────────────
# Which provider to use: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (GPT)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google (Gemini)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-pro

# ── Supabase (cloud storage + uploads database) ───────────
# Create a project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Direct Postgres connection string — used only by the migration runner
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Storage bucket name (create in Supabase Storage → New bucket)
SUPABASE_BUCKET=runpaper-uploads
# How many days before uploaded files expire (default: 30)
UPLOAD_TTL_DAYS=30

# ── Google OAuth2 (sign-in) ───────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── JWT (session signing) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Service URLs ──────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Application settings ──────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional: Semantic Scholar citations ─────────────────
SEMANTIC_SCHOLAR_KEY=

# ── Error monitoring (Sentry) ─────────────────────────────
# Create a project at https://sentry.io — leave empty to disable
SENTRY_DSN=
ENVIRONMENT=development

# ── Pipeline timeout ─────────────────────────────────────────
# Max seconds the 5-step pipeline can run before being killed (default: 600)
PIPELINE_TIMEOUT_SECONDS=600
